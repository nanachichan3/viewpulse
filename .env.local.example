# Viewpulse Environment Variables
# v2.0: 100% client-side, no API keys needed.

# Copy this file to .env.local and fill as needed.

# Application URL (used for sitemap/SEO metadata)
# NEXT_PUBLIC_APP_URL=https://viewpulse.rachkovan.com

# ── OAuth variables removed in v2.0 ──
# YouTube OAuth and Data API are no longer used.
# See OAUTH_SETUP.md for details.